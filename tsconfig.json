{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,                 /* Forzar modo estricto en todo el proyecto */
    "noImplicitAny": true,          /* Bloquear variables que no tengan tipo explícito */
    "strictNullChecks": true,       /* Obligarnos a manejar defensivamente los valores null/undefined */
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*"]
}
