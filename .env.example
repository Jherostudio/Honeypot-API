# Active REST API Honeypot Configuration

# Security: HMAC Secret Key (generates cryptographic signatures for logs)
# CRITICAL: Change this to a strong random value in production
HMAC_SECRET=your-super-secret-hmac-key-change-this-in-production

# Server Configuration
NODE_ENV=development
PORT=3000
HOST=127.0.0.1

# Honeypot Configuration
HONEYPOT_ENABLE=true
LOG_LEVEL=info

# Logging
LOG_DIR=./logs
LOG_FORMAT=jsonl

# Attack Detection Sensitivity (1-10, higher = stricter)
THREAT_SENSITIVITY=7
