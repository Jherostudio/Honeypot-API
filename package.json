{
  "name": "honeypot-api",
  "version": "1.0.0",
  "description": "Active REST API Honeypot for detecting and analyzing malicious traffic patterns",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev -r dotenv/config --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "audit-logs": "ts-node -r dotenv/config src/utils/verifyLogs.ts"
  },
  "keywords": [
    "honeypot",
    "security",
    "threat-detection",
    "api-security"
  ],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^16.6.1",
    "express": "^4.22.2",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.25",
    "@types/node": "^20.19.41",
    "@types/uuid": "^9.0.2",
    "@typescript-eslint/eslint-plugin": "^6.2.1",
    "@typescript-eslint/parser": "^6.2.1",
    "eslint": "^8.45.0",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jherostudio/Honeypot-API.git"
  },
  "types": "./dist/index.d.ts",
  "bugs": {
